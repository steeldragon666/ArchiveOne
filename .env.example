# Template — copy to .env and fill in secrets locally.
# DO NOT put real credentials in this file; it is committed to git.

# Postgres (local dev via docker compose — port 5433 to coexist with any native install on 5432)
# DATABASE_URL    — privileged migration runner (cpa role: superuser, table owner; bypasses RLS)
# DATABASE_URL_APP — application runtime (cpa_app role: NOSUPERUSER, NOBYPASSRLS; RLS applies)
# Migrations run as cpa via tools/migrate.ts. App code connects via packages/db/src/client.ts → cpa_app.
DATABASE_URL=postgres://cpa:cpa@localhost:5433/cpa_dev
DATABASE_URL_APP=postgres://cpa_app:cpa_app_dev_pwd@localhost:5433/cpa_dev
DATABASE_POOL_MAX=10

# Anthropic
ANTHROPIC_API_KEY=

# Voyage AI (embeddings)
VOYAGE_API_KEY=

# Grafana Cloud OTLP
GRAFANA_OTLP_ENDPOINT=
GRAFANA_OTLP_USERNAME=
GRAFANA_OTLP_PASSWORD=

# API
API_PORT=3000
NODE_ENV=development

# Logging (optional; defaults to 'info')
# LOG_LEVEL=debug
