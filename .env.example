# Template — copy to .env and fill in secrets locally.
# DO NOT put real credentials in this file; it is committed to git.

# Postgres (local dev via docker compose — port 5433 to coexist with any native install on 5432)
# DATABASE_URL    — privileged migration runner (cpa role: superuser, table owner; bypasses RLS)
# DATABASE_URL_APP — application runtime (cpa_app role: NOSUPERUSER, NOBYPASSRLS; RLS applies)
# Migrations run as cpa via tools/migrate.ts. App code connects via packages/db/src/client.ts → cpa_app.
DATABASE_URL=postgres://cpa:cpa@localhost:5433/cpa_dev
DATABASE_URL_APP=postgres://cpa_app:cpa_app_dev_pwd@localhost:5433/cpa_dev
DATABASE_POOL_MAX=10

# Anthropic / Classifier
# CLASSIFIER_IMPL selects the R&D evidence classifier:
#   'haiku' — real Anthropic Claude Haiku 4.5 (requires ANTHROPIC_API_KEY)
#   'stub'  — deterministic regex fallback (used in CI; no API key needed)
# Default for dev/prod is 'haiku'; CI overrides to 'stub' in .github/workflows/ci.yml.
CLASSIFIER_IMPL=haiku
# Required when CLASSIFIER_IMPL=haiku. Get from https://console.anthropic.com.
ANTHROPIC_API_KEY=sk-ant-...

# Voyage AI (embeddings)
VOYAGE_API_KEY=

# Grafana Cloud OTLP
GRAFANA_OTLP_ENDPOINT=
GRAFANA_OTLP_USERNAME=
GRAFANA_OTLP_PASSWORD=

# API
API_PORT=3000
NODE_ENV=development

# Logging (optional; defaults to 'info')
# LOG_LEVEL=debug

# === W2 Auth surface ===

# OIDC — Microsoft Entra. Empty values cause /v1/auth/microsoft/* routes to NOT register.
# MICROSOFT_OIDC_TENANT defaults to 'common' (any work/school + personal Microsoft account).
# Use a specific tenant GUID if your firm wants to restrict to one Entra tenant.
MICROSOFT_OIDC_TENANT=common
MICROSOFT_OIDC_CLIENT_ID=
MICROSOFT_OIDC_CLIENT_SECRET=
MICROSOFT_OIDC_REDIRECT_URI=http://localhost:3000/v1/auth/microsoft/callback

# OIDC — Google Workspace. Empty values cause /v1/auth/google/* routes to NOT register.
GOOGLE_OIDC_CLIENT_ID=
GOOGLE_OIDC_CLIENT_SECRET=
GOOGLE_OIDC_REDIRECT_URI=http://localhost:3000/v1/auth/google/callback

# Session JWT signing key. Generate locally via:
#   openssl rand -base64 32
# Production must override the dev default (which is a constant string,
# NOT secure for any non-local environment). The default lives in apps/api/src/app.ts.
SESSION_JWT_SECRET=

# Session cookie name (default: cpa_session). Rarely needs override.
SESSION_COOKIE_NAME=cpa_session

# Session JWT TTL in seconds (default: 86400 = 24h per W2 design Q3).
# Re-auth-on-expiry; no refresh tokens (deferred to P3+).
SESSION_TTL_SECONDS=86400
